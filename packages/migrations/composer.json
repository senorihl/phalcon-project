{
  "name": "senorihl/migrations",
  "description": "Generate & execute database migrations",
  "type": "library",
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "src/loader.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "require": {
    "ext-phalcon": "^5.4",
    "ext-pdo": "*",
    "symfony/console": "^7.2",
    "nette/php-generator": "^4.1",
    "doctrine/sql-formatter": "^1.5"
  }
}